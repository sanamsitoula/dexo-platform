# ============================================================================
# Dexo Platform v5 — example environment
# Copy to .env and adjust. These values match docker-compose.yml (v5) so a
# fresh `docker-compose up -d` + `cp .env.example .env` just works.
# ============================================================================

# Database (matches docker-compose.yml: Postgres on host port 5433, db "dexo")
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/dexo?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379

# JWT
JWT_SECRET="dev-jwt-secret-key-change-in-production"
JWT_EXPIRATION="1h"
REFRESH_TOKEN_SECRET="your-super-secret-refresh-key-change-in-production"
REFRESH_TOKEN_EXPIRATION="7d"

# Bcrypt
BCRYPT_SALT_ROUNDS="10"

# API
PORT=4000
NODE_ENV="development"

# REQUIRED in production (see docs/ci_cd.md). Baked into every frontend's
# browser bundle at `npm run build` time — this is the URL a visitor's
# browser uses to reach the API, so it must be a real, publicly reachable
# address, never "localhost" (that resolves to the visitor's own machine,
# not your server). Leave unset in local dev — each app falls back to
# http://localhost:4000, which is correct for local dev only.
# Production value (matches infra/nginx/dexo.conf's api.onedexo.com block):
# NEXT_PUBLIC_API_URL="https://api.onedexo.com"
CORS_ORIGIN="*"

# Stripe (Mock/Test mode)
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"

# Email / SMTP — System Default tier, last resort (MailHog for local dev — started by docker-compose/run.bat)
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER="test"
SMTP_PASSWORD="test"
EMAIL_FROM="noreply@onedexo.com"

# Global Email Config — Tier 2 (Tenant SMTP overrides this; this overrides
# System Default above). Auto-bootstraps into PlatformEmailConfig on first
# API boot if set; after that, manage via platform-admin Settings -> Email
# instead of these env vars. Leave blank to skip bootstrap and configure via
# the admin UI only. NEVER put real credentials in this .example file.
GLOBAL_SMTP_PROVIDER="brevo"
GLOBAL_SMTP_HOST=""
GLOBAL_SMTP_PORT=587
GLOBAL_SMTP_SECURE=false
GLOBAL_SMTP_USER=""
GLOBAL_SMTP_PASSWORD=""
GLOBAL_SMTP_FROM_NAME="OneDexo"
GLOBAL_SMTP_FROM_EMAIL="noreply@onedexo.com"

# Chatwoot (self-hosted, github.com/chatwoot/chatwoot) — see
# docs/CHATWOOT_INTEGRATION.md and docker-compose.chatwoot.yml. Not required
# for the platform to run — messaging widgets no-op silently if unconfigured.
# Configure the actual connection via platform-admin Settings -> Chat
# instead of env vars; these only seed docker-compose.chatwoot.yml's own
# Rails SECRET_KEY_BASE / FRONTEND_URL for local dev.
CHATWOOT_SECRET_KEY_BASE=""
CHATWOOT_FRONTEND_URL="http://localhost:3200"

# AI plan generation (fitness workout/diet plans) AND the Dexo AI Platform
# agent runtime (/api/ai/chat — see docs/ai/00_AI_MASTER_ARCHITECTURE.md).
# Leave blank to use the rule-based plan fallback + a mock chat provider
# (no external calls, safe for local dev/tests).
ANTHROPIC_API_KEY=""
AI_PLAN_MODEL="claude-sonnet-5"
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# Biometric attendance (ZKTeco data puller)
# ZK_MOCK=true generates sample punches without a physical device.
# ATTENDANCE_AUTO_PULL=true enables the 30-minute scheduled pull of all devices.
ZK_MOCK="true"
ATTENDANCE_AUTO_PULL="false"
# --- ZKTeco live setup (ngrok / on-site server at 10.10.10.4) — kept for later use ---
# External ZKTecoAttendancePuller Postgres (db_config.json equivalent):
#   { "host": "localhost", "port": 5432, "dbname": "zkteco",
#     "user": "postgres", "password": "Nepal@123" }
# When going live via ngrok against the on-site machine (10.10.10.4), uncomment
# and point the puller/devices at it:
# ZKTECO_DB_URL="postgresql://postgres:Nepal%40123@10.10.10.4:5432/zkteco"
# ZK_DEVICE_HOST="10.10.10.4"   # ZKTeco device network (TCP 4370 must be reachable)
# ZK_MOCK="false"

# Customer app URL (used in transactional emails)
TENANT_APP_URL="http://localhost:4007"

# ngrok static domain (reserved on the ngrok dashboard). One free static domain
# = ONE tunnel at a time; pick what to expose:
#   ngrok http 4000 --domain=$NGROK_DOMAIN   # API (webhooks, payment callbacks, mobile)
#   ngrok http 4007 --domain=$NGROK_DOMAIN   # customer app  (open /?tenant=<slug>)
#   ngrok http 80   --domain=$NGROK_DOMAIN   # everything via nginx (deploy/nginx/dexo.conf)
# When exposing the API, start frontends with NEXT_PUBLIC_API_URL=https://$NGROK_DOMAIN
NGROK_DOMAIN="vendetta-oppose-wise.ngrok-free.dev"

# SendGrid (alternative — leave blank for local MailHog)
SENDGRID_API_KEY=""
SENDGRID_FROM="noreply@dexo.com"

# Twilio (SMS)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# S3 / File Storage (MinIO local — matches docker-compose.yml)
S3_REGION="us-east-1"
S3_BUCKET="dexo-uploads"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_ENDPOINT="http://localhost:9000"

# MinIO (local S3 compatible)
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadmin"
MINIO_ENDPOINT="localhost:9000"
MINIO_BUCKET="dexo-uploads"
MINIO_USE_SSL=false

# Frontend URLs
FRONTEND_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"

# Logging
LOG_LEVEL="debug"
LOG_FORMAT="json"

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_TRIAL=true
DEFAULT_TRIAL_DAYS=30

# Dev tenant resolution (hostname middleware reads this in dev)
DEV_TENANT=vrfitness
