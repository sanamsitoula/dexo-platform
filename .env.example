# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dexo_dev?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="1h"
REFRESH_TOKEN_SECRET="your-super-secret-refresh-key-change-in-production"
REFRESH_TOKEN_EXPIRATION="7d"

# Bcrypt
BCRYPT_SALT_ROUNDS="10"

# API
PORT=3000
NODE_ENV="development"
CORS_ORIGIN="*"

# Stripe
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"

# Email / SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="noreply@dexo.com"

# SendGrid (alternative)
SENDGRID_API_KEY="your-sendgrid-api-key"
SENDGRID_FROM="noreply@dexo.com"

# Twilio (SMS)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# S3 / File Storage
S3_REGION="us-east-1"
S3_BUCKET="dexo-uploads"
S3_ACCESS_KEY_ID="your-access-key"
S3_SECRET_ACCESS_KEY="your-secret-key"
S3_ENDPOINT="http://localhost:9000" # For MinIO local

# MinIO (local S3 compatible)
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadmin"
MINIO_ENDPOINT="localhost:9000"
MINIO_BUCKET="dexo-uploads"
MINIO_USE_SSL=false

# Frontend URLs
FRONTEND_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"

# Logging
LOG_LEVEL="debug"
LOG_FORMAT="json"

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_TRIAL=true
DEFAULT_TRIAL_DAYS=30
