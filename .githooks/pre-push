#!/bin/sh
# Blocks pushes where prisma/schema.prisma changed but no migration was added.
# This is exactly the drift that broke CI's clean-DB replay and caused the
# P3009 baseline incident on the production VM (2026-07-15) — a schema edit
# shipped without its migration, so clean databases could never replay history.
#
# Enable once per clone:  git config core.hooksPath .githooks

remote_ref="origin/main"
git rev-parse --verify -q "$remote_ref" >/dev/null || exit 0  # no remote ref yet

schema_changed=$(git diff --name-only "$remote_ref"...HEAD -- prisma/schema.prisma)
if [ -z "$schema_changed" ]; then
  exit 0
fi

new_migrations=$(git diff --name-only --diff-filter=A "$remote_ref"...HEAD -- 'prisma/migrations/*/migration.sql')
if [ -z "$new_migrations" ]; then
  echo ""
  echo "✖ PUSH BLOCKED: prisma/schema.prisma changed but no new migration was added."
  echo ""
  echo "  Every schema change must ship with its migration in the same push,"
  echo "  or CI's clean-database replay (and the next deploy) will break."
  echo ""
  echo "  Fix:  npx prisma migrate dev --name <describe_change>"
  echo "        git add prisma/migrations && git commit --amend (or a new commit)"
  echo ""
  echo "  (Emergency override, only if you are certain: git push --no-verify)"
  echo ""
  exit 1
fi

exit 0
