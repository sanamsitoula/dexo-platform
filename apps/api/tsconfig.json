{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "noEmit": false,
    "module": "commonjs",
    "target": "ES2020",
    "lib": [
      "ES2020"
    ],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {}
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test"
  ]
}
