// ==========================================
// VOUCHER & COUPON MODELS
// ==========================================

enum VoucherType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_TRIAL
  FREE_PLAN
}

enum VoucherStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  DEPLETED
}

model Voucher {
  id           String        @id @default(uuid())
  code         String        @unique
  description  String?
  type         VoucherType
  value        Decimal       @db.Decimal(10, 2) // Percentage or fixed amount
  maxDiscount  Decimal?      @db.Decimal(10, 2) // Max discount for percentage type
  minPurchase  Decimal?      @db.Decimal(10, 2) // Min purchase amount
  currency     String?       @default("USD")
  usageLimit   Int? // Total usage limit
  usageCount   Int           @default(0)
  perUserLimit Int           @default(1)
  planId       String? // Restrict to specific plan
  tenantId     String? // Restrict to specific tenant (null = all tenants)
  startsAt     DateTime?
  expiresAt    DateTime?
  status       VoucherStatus @default(ACTIVE)
  createdBy    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  redemptions VoucherRedemption[]

  @@index([code])
  @@index([status])
  @@index([expiresAt])
}

model VoucherRedemption {
  id             String   @id @default(uuid())
  voucher        Voucher  @relation(fields: [voucherId], references: [id])
  voucherId      String
  user           User?    @relation(fields: [userId], references: [id])
  userId         String?
  tenantId       String?
  email          String // Email used for redemption
  orderId        String? // Associated order/subscription
  discountAmount Decimal  @db.Decimal(10, 2)
  redeemedAt     DateTime @default(now())

  @@index([voucherId])
  @@index([userId])
  @@index([email])
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  BOGO // Buy One Get One
  FREE_SHIPPING
}

enum CouponStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  DEPLETED
}

model Coupon {
  id              String       @id @default(uuid())
  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  tenantId        String
  code            String
  name            String
  description     String?
  type            CouponType
  value           Decimal      @db.Decimal(10, 2)
  maxDiscount     Decimal?     @db.Decimal(10, 2)
  minPurchase     Decimal?     @db.Decimal(10, 2)
  currency        String?      @default("USD")
  usageLimit      Int?
  usageCount      Int          @default(0)
  perUserLimit    Int          @default(1)
  appliesTo       Json? // Product/service restrictions
  customerSegment Json? // Customer segment restrictions
  startsAt        DateTime?
  expiresAt       DateTime?
  status          CouponStatus @default(ACTIVE)
  createdBy       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  redemptions CouponRedemption[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
  @@index([expiresAt])
}

model CouponRedemption {
  id             String   @id @default(uuid())
  coupon         Coupon   @relation(fields: [couponId], references: [id])
  couponId       String
  user           User?    @relation(fields: [userId], references: [id])
  userId         String?
  email          String
  orderId        String?
  discountAmount Decimal  @db.Decimal(10, 2)
  redeemedAt     DateTime @default(now())

  @@index([couponId])
  @@index([userId])
  @@index([email])
}

