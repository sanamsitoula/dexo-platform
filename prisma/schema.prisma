  user     User?   @relation(fields: [userId], references: [id])
  userId   String?

  name          String
  email         String?
  phone         String?
  subject       String?
  qualification String?

  classes Class[]

  createdAt DateTime @default(now())

  @@index([tenantId])
}

model Class {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  name      String
  grade     String?
  section   String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
  teacherId String?

  students Enrollment[]

  createdAt DateTime @default(now())

  @@index([tenantId])
}

model Enrollment {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  student   Student @relation(fields: [studentId], references: [id])
  studentId String
  class     Class   @relation(fields: [classId], references: [id])
  classId   String

  enrolledAt DateTime @default(now())

  @@unique([studentId, classId])
  @@index([tenantId])
}

model Exam {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  name         String
  subject      String
  totalMarks   Int
  passingMarks Int
  examDate     DateTime

  results ExamResult[]

  createdAt DateTime @default(now())

  @@index([tenantId])
}

model ExamResult {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  student   Student @relation(fields: [studentId], references: [id])
  studentId String
  exam      Exam    @relation(fields: [examId], references: [id])
  examId    String

  marksObtained Int
  grade         String?
  remarks       String?

  @@unique([studentId, examId])
  @@index([tenantId])
}

// =====================================================
// FITNEPAL FITNESS DOMAIN MODELS
// =====================================================

enum MembershipType {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  TRIAL
  CUSTOM
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  FROZEN
  CANCELLED
  PENDING
}

enum BodyAssessmentType {
  INITIAL
  PERIODIC
  FINAL
}

enum WorkoutPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum WorkoutLogStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum DietPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum MealType {
  BREAKFAST
  MORNING_SNACK
  LUNCH
  AFTERNOON_SNACK
  DINNER
  EVENING_SNACK
  LATE_NIGHT
}

enum ClassType {
  YOGA
  ZUMBA
  CROSSFIT
  SPINNING
  PILATES
  AEROBICS
  BOXING
  HIIT
  STRENGTH
  CARDIO
  FUNCTIONAL
  OTHER
}

enum AttendanceMethod {
  QR_CODE
  MANUAL
  BIOMETRIC
  NFC
}

enum BadgeCategory {
  STREAK
  MILESTONE
  ACHIEVEMENT
  CHALLENGE
  SOCIAL
}

enum ReferralStatus {
  PENDING
  ACCEPTED
  COMPLETED
  EXPIRED
}

// Membership Plans (defined by gym)
model MembershipPlan {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  name         String
  description  String?        @db.Text
  type         MembershipType
  durationDays Int

  // Pricing in NPR
  priceNpr     Decimal @db.Decimal(10, 2)
  vatPercent   Decimal @default(13) @db.Decimal(5, 2)
  totalWithVat Decimal @db.Decimal(10, 2)

  // Features
  includesTrainer  Boolean @default(false)
  includesClasses  Boolean @default(false)
  includesDietPlan Boolean @default(false)
  includesLocker   Boolean @default(false)
  freezeAllowed    Boolean @default(true)
  maxFreezeDays    Int     @default(30)

  // Access
  accessHours  String? @db.Text // "24/7" or "6AM-10PM"
  branchAccess String  @default("single") // "single" or "all"

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  // Relations
  memberships Membership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([type])
}

// Customer Memberships
model Membership {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  member   Member @relation(fields: [memberId], references: [id])
  memberId String

  plan   MembershipPlan @relation(fields: [planId], references: [id])
  planId String

  status    MembershipStatus @default(PENDING)
  startDate DateTime
  endDate   DateTime

  // Payment
  amountPaid    Decimal @db.Decimal(10, 2)
  paymentMethod String? // eSewa, Khalti, ConnectIPS, Cash
  paymentRef    String? // Transaction reference

  // Freeze support
  isFrozen     Boolean   @default(false)
  frozenAt     DateTime?
  frozenDays   Int       @default(0)
  freezeReason String?   @db.Text

  // QR Code for check-in
  qrCode String? @unique

  // Auto-renewal
  autoRenew       Boolean @default(false)
  renewBeforeDays Int     @default(7)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  attendances   Attendance[]
  classBookings ClassBooking[]
  reminderLogs  ReminderLog[]

  @@index([tenantId])
  @@index([memberId])
  @@index([status])
  @@index([endDate])
}

// Tracks membership expiry/renewal reminders already sent, so the daily
// cron job never double-sends the same milestone notification.
model ReminderLog {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  membershipId String

  milestone String // "7_DAYS", "3_DAYS", "1_DAY", "EXPIRED"
  sentAt    DateTime @default(now())

  createdAt DateTime @default(now())

  @@unique([membershipId, milestone])
  @@index([tenantId])
  @@index([membershipId])
}

// Body Assessment & Health Tracking
model BodyAssessment {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  member   Member @relation(fields: [memberId], references: [id])
  memberId String

  assessmentType BodyAssessmentType

  // Basic measurements
  weight         Decimal? @db.Decimal(5, 2) // kg
  height         Decimal? @db.Decimal(5, 2) // cm
  bmi            Decimal? @db.Decimal(4, 2)
  bodyFatPercent Decimal? @db.Decimal(4, 2)
  muscleMass     Decimal? @db.Decimal(5, 2) // kg

  // Body measurements (in cm)
  waist  Decimal? @db.Decimal(5, 2)
  chest  Decimal? @db.Decimal(5, 2)
  hips   Decimal? @db.Decimal(5, 2)
  arms   Decimal? @db.Decimal(5, 2)
  thighs Decimal? @db.Decimal(5, 2)
  calves Decimal? @db.Decimal(5, 2)

  // Health metrics
  restingHeartRate Int?
  bloodPressure    String? // "120/80"
  bloodSugar       Decimal? @db.Decimal(5, 2) // mg/dL
  cholesterol      Decimal? @db.Decimal(5, 2) // mg/dL

  // Health conditions & injuries
  healthConditions String? @db.Text
  injuries         String? @db.Text
  medications      String? @db.Text

  // Fitness level & goals
  fitnessLevel String? // BEGINNER, INTERMEDIATE, ADVANCED
  goalType     String? // WEIGHT_LOSS, MUSCLE_GAIN, ENDURANCE, GENERAL_FITNESS
  targetWeight Decimal?  @db.Decimal(5, 2)
  targetDate   DateTime?

  // Notes
  trainerNotes String? @db.Text

  assessedBy String? // Trainer user ID
  assessedAt DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([memberId])
  @@index([assessedAt])
}

// Workout Plans (AI-generated + trainer approved)
model WorkoutPlan {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  member   Member @relation(fields: [memberId], references: [id])
  memberId String

  trainer   Trainer? @relation(fields: [trainerId], references: [id])
  trainerId String?

  name         String
  description  String? @db.Text
  goalType     String? // WEIGHT_LOSS, MUSCLE_GAIN, ENDURANCE, GENERAL
  fitnessLevel String? // BEGINNER, INTERMEDIATE, ADVANCED

  durationWeeks Int @default(4)
  daysPerWeek   Int @default(4)

  status        WorkoutPlanStatus @default(DRAFT)
  isAiGenerated Boolean           @default(false)
  aiPrompt      String?           @db.Text
  aiResponse    String?           @db.Text

  approvedBy String? // Trainer who approved
  approvedAt DateTime?

  startDate DateTime?
  endDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  workoutDays WorkoutDay[]
  workoutLogs WorkoutLog[]

  @@index([tenantId])
  @@index([memberId])
  @@index([status])
}

// Workout Day (part of a plan)
model WorkoutDay {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  plan   WorkoutPlan @relation(fields: [planId], references: [id])
  planId String

  dayNumber   Int // 1-7
  dayName     String // "Monday", "Push Day", etc.
  muscleGroup String? // "Chest & Triceps", "Full Body", etc.
  isRestDay   Boolean @default(false)

  notes String? @db.Text

  createdAt DateTime @default(now())

  // Relations
  exercises WorkoutExercise[]

  @@index([tenantId])
  @@index([planId])
}

// Exercise in a workout day
model WorkoutExercise {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  day   WorkoutDay @relation(fields: [dayId], references: [id])
  dayId String

  name        String
  description String? @db.Text
  videoUrl    String? // Exercise demo video

  // Prescription
  sets        Int?
  reps        Int?
  weight      Decimal? @db.Decimal(6, 2) // kg
  duration    Int? // seconds (for cardio/planks)
  restSeconds Int      @default(60)

  // Order
  sortOrder Int @default(0)

  // Equipment needed
  equipment String? // "Barbell", "Dumbbell", "Bodyweight", etc.

  // Back-relations
  exerciseLogs ExerciseLog[]

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([dayId])
}

// Daily Workout Log
model WorkoutLog {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  member   Member @relation(fields: [memberId], references: [id])
  memberId String

  plan   WorkoutPlan? @relation(fields: [planId], references: [id])
  planId String?

  workoutDate DateTime
  status      WorkoutLogStatus @default(PLANNED)

  duration       Int? // minutes
  caloriesBurned Int?

  notes  String? @db.Text
  rating Int? // 1-5 stars

  loggedAt DateTime @default(now())

  // Relations
  exerciseLogs ExerciseLog[]

  @@index([tenantId])
  @@index([memberId])
  @@index([workoutDate])
}

// Individual exercise log entry
model ExerciseLog {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  workoutLog   WorkoutLog @relation(fields: [workoutLogId], references: [id])
  workoutLogId String

  exercise   WorkoutExercise @relation(fields: [exerciseId], references: [id])
  exerciseId String

  // Actual performance
  setsCompleted Int
  repsCompleted Int?
  weightUsed    Decimal? @db.Decimal(6, 2)
  duration      Int? // seconds

  notes String?

  @@index([tenantId])
  @@index([workoutLogId])
  @@index([exerciseId])
}

// Diet Plans (AI-generated with Nepali foods)
model DietPlan {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  member   Member @relation(fields: [memberId], references: [id])
  memberId String

  name        String
  description String? @db.Text

  // Nutrition targets
  dailyCalories Int
  proteinGrams  Int?
  carbsGrams    Int?
  fatsGrams     Int?
  fiberGrams    Int?

  // Dietary preferences
  dietType  String? // VEGETARIAN, NON_VEGETARIAN, VEGAN, KETO
  allergies String? @db.Text

  status        DietPlanStatus @default(DRAFT)
  isAiGenerated Boolean        @default(false)

  approvedBy String?
  approvedAt DateTime?

  startDate DateTime?
  endDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  meals    DietMeal[]
  foodLogs FoodLog[]

  @@index([tenantId])
  @@index([memberId])
}

// Diet Meal (part of a diet plan)
model DietMeal {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  plan   DietPlan @relation(fields: [planId], references: [id])
  planId String

  mealType  MealType
  dayOfWeek Int? // 0-6, null = every day

  name        String // "Breakfast", "Morning Snack", etc.
  description String? @db.Text

  // Food items (JSON array of {name, quantity, calories, protein, carbs, fats})
  foodItems Json?

  // Totals
  totalCalories Int?
  totalProtein  Decimal? @db.Decimal(5, 2)
  totalCarbs    Decimal? @db.Decimal(5, 2)
  totalFats     Decimal? @db.Decimal(5, 2)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([planId])
}

// Daily Food Log
model FoodLog {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  member   Member @relation(fields: [memberId], references: [id])
  memberId String

  plan   DietPlan? @relation(fields: [planId], references: [id])
  planId String?

  logDate  DateTime
  mealType MealType

  // Food items consumed
  foodItems Json? // Array of {name, quantity, calories, protein, carbs, fats}

  // Totals
  totalCalories Int?
  totalProtein  Decimal? @db.Decimal(5, 2)
  totalCarbs    Decimal? @db.Decimal(5, 2)
  totalFats     Decimal? @db.Decimal(5, 2)

  waterIntake Int? // ml
  notes       String?

  loggedAt DateTime @default(now())

  @@index([tenantId])
  @@index([memberId])
  @@index([logDate])
}

// Group Fitness Classes
model GroupClass {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  name        String
  description String?   @db.Text
  classType   ClassType

  trainer   Trainer? @relation(fields: [trainerId], references: [id])
  trainerId String?

  branch   Branch? @relation(fields: [branchId], references: [id])
  branchId String?

  // Schedule
  dayOfWeek Int // 0-6 (Sunday-Saturday)
  startTime DateTime
  endTime   DateTime
  duration  Int // minutes

  // Capacity
  maxCapacity  Int @default(20)
  currentCount Int @default(0)

  // Pricing
  isFree   Boolean  @default(false)
  priceNpr Decimal? @db.Decimal(10, 2)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bookings ClassBooking[]

  @@index([tenantId])
  @@index([classType])
  @@index([dayOfWeek])
}

// Class Booking
model ClassBooking {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  member   Member @relation(fields: [memberId], references: [id])
  memberId String

  class   GroupClass @relation(fields: [classId], references: [id])
  classId String

  membership   Membership? @relation(fields: [membershipId], references: [id])
  membershipId String?

  bookingDate DateTime
  status      String   @default("BOOKED") // BOOKED, ATTENDED, CANCELLED, NO_SHOW

  bookedAt    DateTime  @default(now())
  cancelledAt DateTime?

  @@unique([memberId, classId, bookingDate])
  @@index([tenantId])
  @@index([memberId])
  @@index([bookingDate])
}

// Trainer- Customer Chat Messages
model TrainerMessage {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  member   Member @relation(fields: [memberId], references: [id])
  memberId String

  trainer   Trainer? @relation(fields: [trainerId], references: [id])
  trainerId String?

  senderType String // "TRAINER", "MEMBER", "SYSTEM"
  message    String @db.Text

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([memberId])
  @@index([createdAt])
}

// Badges & Achievements
model Badge {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  name        String
  description String?       @db.Text
  icon        String? // Icon name or emoji
  category    BadgeCategory

  // Criteria (JSON: {type: "streak", days: 7} or {type: "workouts", count: 50})
  criteria Json

  // Points/rewards
  points    Int      @default(0)
  rewardNpr Decimal? @db.Decimal(10, 2)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  // Relations
  earnedBy CustomerBadge[]

  @@index([tenantId])
  @@index([category])
}

// Customer Earned Badges
model CustomerBadge {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  member   Member @relation(fields: [memberId], references: [id])
  memberId String

  badge   Badge  @relation(fields: [badgeId], references: [id])
  badgeId String

  earnedAt DateTime @default(now())

  @@unique([memberId, badgeId])
  @@index([tenantId])
  @@index([memberId])
}

// Referral System
model Referral {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  referrer   Member @relation("Referrer", fields: [referrerId], references: [id])
  referrerId String

  referee   Member? @relation("Referee", fields: [refereeId], references: [id])
  refereeId String?

  referralCode String  @unique
  refereeEmail String?
  refereePhone String?

  status ReferralStatus @default(PENDING)

  // Reward
  rewardType  String? // "DISCOUNT", "FREE_DAYS", "CASHBACK"
  rewardValue Decimal? @db.Decimal(10, 2)

  completedAt DateTime?
  expiresAt   DateTime?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([referrerId])
  @@index([referralCode])
}

// Gym Equipment & Inventory
model Equipment {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  branch   Branch? @relation(fields: [branchId], references: [id])
  branchId String?

  name         String
  category     String // "CARDIO", "STRENGTH", "FREE_WEIGHTS", "MACHINES", "ACCESSORIES"
  brand        String?
  model        String?
  serialNumber String?

  quantity  Int    @default(1)
  condition String @default("GOOD") // NEW, GOOD, FAIR, NEEDS_REPAIR, OUT_OF_SERVICE

  purchaseDate  DateTime?
  purchaseCost  Decimal?  @db.Decimal(10, 2)
  warrantyUntil DateTime?

  lastMaintenance DateTime?
  nextMaintenance DateTime?

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  maintenanceLogs EquipmentMaintenance[]

  @@index([tenantId])
  @@index([branchId])
  @@index([category])
}

// Equipment Maintenance Logs
model EquipmentMaintenance {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  equipmentId String

  maintenanceType String // ROUTINE, REPAIR, INSPECTION
  description     String @db.Text

  cost        Decimal? @db.Decimal(10, 2)
  performedBy String?

  performedAt DateTime  @default(now())
  nextService DateTime?

  @@index([tenantId])
  @@index([equipmentId])
}

// Nepali Food Database (for diet plans)
model NepaliFoodItem {
  id String @id @default(uuid())

  name       String // "Dal Bhat", "Momo", "Roti", etc.
  nameNepali String? // "दाल भात", "मम", etc.
  category   String // "STAPLE", "VEGETABLE", "FRUIT", "PROTEIN", "SNACK", "BEVERAGE"

  // Nutrition per serving
  servingSize String // "1 cup", "1 piece", "100g"
  calories    Int
  protein     Decimal  @db.Decimal(5, 2)
  carbs       Decimal  @db.Decimal(5, 2)
  fats        Decimal  @db.Decimal(5, 2)
  fiber       Decimal? @db.Decimal(5, 2)

  // Dietary info
  isVegetarian Boolean @default(true)
  isVegan      Boolean @default(false)
  allergens    String? // Comma-separated: "gluten,nuts,dairy"

  // Common in Nepal
  isTraditional Boolean @default(false)
  region        String? // "HILL", "TERAI", "NEWARI", "GENERAL"

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([category])
  @@index([name])
}

// =============================================================================
//  DEXO v5 — Phase 1 Schema Additions
//  BusinessTypeTemplate, CustomerOnboarding, TenantOnboarding, TenantLifecycle
// =============================================================================

enum LifecycleStatus {
  PROVISIONING
  ACTIVE
  SUSPENDED
  ARCHIVED
  DELETION_SCHEDULED
  DELETED
}

enum SslStatus {
  PENDING
  ACTIVE
  FAILED
  EXPIRED
}

model BusinessTypeTemplate {
  id              String     @id @default(uuid())
  domainType      DomainType @unique
  name            String
  description     String
  tagline         String
  heroImage       String?
  colorPrimary    String
  colorAccent     String
  colorBg         String
  fontHeading     String     @default("Inter")
  fontBody        String     @default("Inter")
  websiteSections Json
  onboardingSteps Json
  dashboardLayout Json
  features        Json
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model CustomerOnboarding {
  id          String    @id @default(uuid())
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId    String
  user        User?     @relation(fields: [userId], references: [id])
  userId      String?
  email       String
  step        Int       @default(1)
  totalSteps  Int
  data        Json
  completed   Boolean   @default(false)
  completedAt DateTime?
  source      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([email])
  @@index([completed])
}

model TenantOnboarding {
  id               String    @id @default(uuid())
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId         String    @unique
  step             Int       @default(1)
  totalSteps       Int       @default(6)
  completed        Boolean   @default(false)
  completedAt      DateTime?
  profileComplete  Boolean   @default(false)
  brandingComplete Boolean   @default(false)
  modulesComplete  Boolean   @default(false)
  teamComplete     Boolean   @default(false)
  websiteComplete  Boolean   @default(false)
  billingComplete  Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model TenantLifecycle {
  id                   String          @id @default(uuid())
  tenant               Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId             String          @unique
  status               LifecycleStatus @default(PROVISIONING)
  subdomainSlug        String          @unique
  customDomain         String?         @unique
  customDomainVerified Boolean         @default(false)
  dnsToken             String?
  sslStatus            SslStatus       @default(PENDING)
  suspendedAt          DateTime?
  suspendedBy          String?
  suspendReason        String?
  archivedAt           DateTime?
  archivedBy           String?
  deletedAt            DateTime?
  deletedBy            String?
  deletionScheduledAt  DateTime?
  provisionedAt        DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([status])
  @@index([subdomainSlug])
  @@index([customDomain])
}

// =============================================================================
//  BIOMETRIC ATTENDANCE (ZKTeco) — device registry, data puller & reports
//  Modeled after github.com/sanamsitoula/ZKTecoAttendancePuller
//  (devices / attendance_logs / pull_sessions). Punches land in Attendance.
// =============================================================================

model AttendanceDevice {
  id       String  @id @default(uuid())
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  tenantId String
  branch   Branch? @relation(fields: [branchId], references: [id])
  branchId String?

  name       String
  ip         String
  port       Int     @default(4370)
  commKey    String? // device password, default blank/0
  model      String? // e.g. "K40", "iFace302"
  forceUdp   Boolean @default(false) // older models (iFace302) need UDP
  timeoutSec Int     @default(10)

  isActive   Boolean   @default(true)
  lastPullAt DateTime?
  lastStatus String? // OK / FAILED / NEVER

  pullSessions AttendancePullSession[]
  attendances  Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, ip, port])
  @@index([tenantId])
}

model AttendancePullSession {
  id       String           @id @default(uuid())
  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  tenantId String
  device   AttendanceDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId String

  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  status        String    @default("RUNNING") // RUNNING / SUCCESS / FAILED
  recordsPulled Int       @default(0)
  newInserts    Int       @default(0)
  errorDetail   String?   @db.Text

  @@index([tenantId])
  @@index([deviceId])
  @@index([startedAt])
}

// =====================================================
// ECOMMERCE DOMAIN MODELS
// =====================================================
// Catalog -> Inventory -> Cart -> SalesOrder -> Shipment.
// Finance is deliberately decoupled from Invoice/JournalEntry for v1 (see
// docs/ECOMMERCE_MODULE.md Roadmap section) -- SalesOrder can optionally link
// to an Invoice once the checkout-to-invoice-to-GL posting flow is built,
// mirroring the fitness deferred-revenue pattern in FitnessFinanceService.

enum EcommerceOrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum ShipmentStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
}

enum StockMovementReason {
  PURCHASE_RECEIPT
  SALE
  SALE_RETURN
  PURCHASE_RETURN
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
}

model ProductCategory {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  name     String
  slug     String
  parent   ProductCategory?  @relation("CategoryChildren", fields: [parentId], references: [id])
  parentId String?
  children ProductCategory[] @relation("CategoryChildren")

  products  Product[]
  createdAt DateTime  @default(now())

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Brand {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  name    String
  logoUrl String?

  products  Product[]
  createdAt DateTime  @default(now())

  @@index([tenantId])
}

model Product {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  category   ProductCategory? @relation(fields: [categoryId], references: [id])
  categoryId String?
  brand      Brand?           @relation(fields: [brandId], references: [id])
  brandId    String?

  sku            String
  barcode        String?
  name           String
  slug           String
  description    String?  @db.Text
  images         Json?
  costPrice      Decimal  @default(0) @db.Decimal(12, 2)
  sellingPrice   Decimal  @db.Decimal(12, 2)
  taxRatePercent Decimal  @default(0) @db.Decimal(5, 2)
  trackInventory Boolean  @default(true)
  isActive       Boolean  @default(true)
  isFeatured     Boolean  @default(false)
  reorderPoint   Int?     // low-stock alert threshold; null = no alerting
  metaTitle       String?
  metaDescription String? @db.Text

  variants    ProductVariant[]
  stockItems  StockItem[]
  stockLedger StockLedgerEntry[]
  cartItems   CartItem[]
  orderItems  SalesOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, slug])
  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([categoryId])
}

model ProductVariant {
  id        String  @id @default(uuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  sku           String
  attributes    Json // legacy free-form snapshot (kept for display); structured values live in attributeValues below
  priceOverride Decimal? @db.Decimal(12, 2)
  barcode       String?

  attributeValues ProductVariantAttributeValue[]
  stockItems      StockItem[]
  cartItems       CartItem[]
  orderItems      SalesOrderItem[]
  createdAt       DateTime                       @default(now())

  @@unique([productId, sku])
}

model Warehouse {
  id       String  @id @default(uuid())
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  tenantId String
  branch   Branch? @relation(fields: [branchId], references: [id])
  branchId String?

  name      String
  code      String
  address   String?
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  stockItems  StockItem[]
  stockLedger StockLedgerEntry[]
  shipments   Shipment[]
  createdAt   DateTime           @default(now())

  @@unique([tenantId, code])
  @@index([tenantId])
}

model StockItem {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  product     Product         @relation(fields: [productId], references: [id])
  productId   String
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  variantId   String?
  warehouse   Warehouse       @relation(fields: [warehouseId], references: [id])
  warehouseId String

  quantityOnHand   Int      @default(0)
  quantityReserved Int      @default(0)
  updatedAt        DateTime @updatedAt

  @@unique([productId, variantId, warehouseId])
  @@index([tenantId])
  @@index([warehouseId])
}

model StockLedgerEntry {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  product     Product   @relation(fields: [productId], references: [id])
  productId   String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  warehouseId String

  quantityChange Int
  balanceAfter   Int
  reason         StockMovementReason
  refType        String?
  refId          String?
  createdAt      DateTime            @default(now())

  @@index([tenantId])
  @@index([productId])
}

model Cart {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?
  sessionId  String?

  status   CartStatus @default(ACTIVE)
  currency String     @default("NPR")

  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([tenantId])
  @@index([customerId])
}

model CartItem {
  id     String @id @default(uuid())
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId String

  product   Product         @relation(fields: [productId], references: [id])
  productId String
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  variantId String?

  quantity  Int
  unitPrice Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  @@index([cartId])
}

model SalesOrder {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?
  invoice    Invoice?  @relation(fields: [invoiceId], references: [id])
  invoiceId  String?   @unique

  orderNumber     String
  status          EcommerceOrderStatus @default(PENDING)
  subtotal        Decimal              @db.Decimal(12, 2)
  discountTotal   Decimal              @default(0) @db.Decimal(12, 2)
  taxTotal        Decimal              @default(0) @db.Decimal(12, 2)
  shippingTotal   Decimal              @default(0) @db.Decimal(12, 2)
  grandTotal      Decimal              @db.Decimal(12, 2)
  currency        String               @default("NPR")
  couponCode      String?
  shippingAddress Json?
  paymentMethod   OrderPaymentMethod   @default(PREPAID)

  items     SalesOrderItem[]
  shipments Shipment[]
  placedAt  DateTime          @default(now())

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([customerId])
}

model SalesOrderItem {
  id      String     @id @default(uuid())
  order   SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  product   Product         @relation(fields: [productId], references: [id])
  productId String
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  variantId String?

  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  taxAmount Decimal @default(0) @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  @@index([orderId])
}

model Shipment {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  order       SalesOrder @relation(fields: [orderId], references: [id])
  orderId     String
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  warehouseId String?

  courierName    String?
  trackingNumber String?
  status         ShipmentStatus @default(PENDING)
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime       @default(now())

  @@index([tenantId])
  @@index([orderId])
}

// =====================================================
// ECOMMERCE V2 — Attributes/Variations, Reorder Alerts,
// SEO fields, COD, generic Webhooks
// =====================================================

// Event types are free-form strings (not an enum) by design: any module can
// emit a new event ("salon.appointment.booked", "school.exam.published", ...)
// without a schema migration. Conventional dot-namespaced names, mirrored in
// WebhooksService callers, e.g. order.created / order.status_changed /
// order.cancelled / shipment.created / shipment.status_changed / product.low_stock.

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
  DEAD
}

enum OrderPaymentMethod {
  COD
  PREPAID
}

// A reusable option group, e.g. "Size" or "Color" — defined once per tenant, attached to many products.
model ProductAttribute {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  name   String // "Size", "Color"
  values ProductAttributeValue[]

  createdAt DateTime @default(now())

  @@unique([tenantId, name])
  @@index([tenantId])
}

// A concrete option, e.g. "Red" under the "Color" attribute.
model ProductAttributeValue {
  id          String           @id @default(uuid())
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  attributeId String

  value String // "Red", "M"

  variantLinks ProductVariantAttributeValue[]
  createdAt    DateTime                       @default(now())

  @@unique([attributeId, value])
}

// Join row: which attribute value a given variant carries (Size=M AND Color=Red).
model ProductVariantAttributeValue {
  id        String         @id @default(uuid())
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantId String

  value   ProductAttributeValue @relation(fields: [valueId], references: [id])
  valueId String

  @@unique([variantId, valueId])
}

// Tenant-configured outbound webhook — the generic "plug and play" event bus
// every module can emit into (see WebhooksService.emit in
// apps/api/src/modules/webhooks). A tenant subscribes a URL to one or more
// event types; deliveries are logged for observability/debugging.
model WebhookEndpoint {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String

  url        String
  eventTypes String[] // e.g. ["order.created", "shipment.status_changed"]
  secret     String   // HMAC-SHA256 signs the X-Dexo-Signature header
  isActive   Boolean  @default(true)
  label      String?

  deliveries WebhookDelivery[]
  createdAt  DateTime          @default(now())

  @@index([tenantId])
}

model WebhookDelivery {
  id         String          @id @default(uuid())
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  endpointId String

  eventType      String
  payload        Json
  status         WebhookDeliveryStatus @default(PENDING)
  responseStatus Int?
  attempts       Int                   @default(0)
  lastError      String?
  createdAt      DateTime              @default(now())
  deliveredAt    DateTime?
  // Retry-with-backoff (added for retry worker — see WebhooksService.retryFailedDeliveries):
  // nextRetryAt is when the @Cron sweep should next attempt redelivery; null once
  // SUCCESS or DEAD (max attempts exhausted, 5).
  nextRetryAt    DateTime?

  @@index([endpointId])
  @@index([status])
  @@index([nextRetryAt])
}

// Explicit, platform-admin-controlled per-tenant module grant/restriction —
// takes precedence over the subscription plan's features.modules config
// (which is plan-wide, not tenant-specific). This is what makes module
// access a true hierarchy: Platform Admin can grant/revoke any module for
// any tenant regardless of what plan they're on; ModuleAccessGuard checks
// this table FIRST, then falls back to the plan config for backward
// compatibility. See docs/RBAC_ARCHITECTURE.md.
model TenantModuleOverride {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String

  moduleKey String // "ecommerce", "crm", "billing_invoice", ...
  enabled   Boolean

  setBy     String? // platform admin User.id who set this override
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, moduleKey])
  @@index([tenantId])
}

// Full audit trail of every AI agent interaction — required by the AI
// platform's safety rules (never bypass permissions, log every action,
// record tool execution history). One row per chat turn; toolCalls captures
// exactly which tools ran with which args and results, so any AI-initiated
// action (e.g. sendReminder) is fully traceable to who asked for it.
model AiInteractionLog {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String
  userId   String

  agentKey    String
  userMessage String @db.Text
  reply       String @db.Text
  toolCalls   Json // [{ tool, args, result }]

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([agentKey])
}

// =====================================================
// GLOBAL EMAIL SYSTEM (Platform-configurable, provider-agnostic)
// =====================================================
// Hierarchy: Tenant SMTP (Setting key "smtp", see TenantMailService) ->
// PlatformEmailConfig (this model, super-admin-editable via
// /api/platform-email, no redeploy needed) -> System Default (SMTP_* env
// vars, last-resort dev fallback). No email provider name is hardcoded in
// business logic anywhere — "provider" here is a free-text label
// ("brevo", "smtp", "sendgrid", ...) purely for the admin UI/monitoring.

model PlatformEmailConfig {
  id String @id @default(uuid())

  provider String @default("smtp") // free-text label, not an enum — new providers need no migration
  isEnabled Boolean @default(true)

  host     String
  port     Int     @default(587)
  secure   Boolean @default(false)
  user     String?
  pass     String?

  fromName  String?
  fromEmail String
  replyTo   String?

  dailyLimit   Int?
  monthlyLimit Int?

  lastTestedAt   DateTime?
  lastTestStatus String? // "SUCCESS" | "FAILED"
  lastTestError  String?

  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformEmailLog {
  id       String  @id @default(uuid())
  tenantId String? // null = a platform-level send (no tenant context)

  to      String
  subject String
  via     String // "tenant" | "global" | "system"
  status  String // "SENT" | "FAILED"

  messageId String?
  error     String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
}

// =====================================================
// CHATWOOT INTEGRATION (self-hosted, github.com/chatwoot/chatwoot)
// =====================================================
// Three-tier messaging flow:
//   Tier 1  Customer <-> Tenant   — one Chatwoot Website inbox PER TENANT
//           (TenantChatwootConfig), embedded via the tenant's own widget
//           script on tenant-website/tenant-app. Gym customer <-> gym
//           owner/trainer, etc.
//   Tier 2  Tenant <-> Platform   — a SINGLE platform-wide Website inbox
//           (PlatformChatwootConfig.platformInboxId) embedded in
//           tenant-admin. Gym owner <-> platform support/owner.
// Chatwoot itself is the source of truth for conversations/messages/agents —
// these models only store the connection + per-tenant inbox mapping needed
// to provision and embed it. See docs/CHATWOOT_INTEGRATION.md.

model PlatformChatwootConfig {
  id String @id @default(uuid())

  baseUrl          String // e.g. https://chatwoot.onedexo.com
  apiAccessToken   String? // platform-level API access token (masked in API responses)
  platformAccountId Int?   // the Chatwoot "account" every tenant inbox is created under
  platformInboxId   Int?   // the single Tier-2 inbox: tenant owners <-> platform
  platformWebsiteToken String? // widget script token for the Tier-2 inbox
  isEnabled        Boolean @default(false)

  lastTestedAt   DateTime?
  lastTestStatus String?
  lastTestError  String?

  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TenantChatwootConfig {
  id       String @id @default(uuid())
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId String @unique

  inboxId       Int?    // Chatwoot inbox id for this tenant's Tier-1 (customer<->tenant) inbox
  websiteToken  String? // widget script token for this tenant's inbox
  contactEmail  String? // tenant owner's email, registered as a Tier-2 contact under the platform inbox

  provisionedAt DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
