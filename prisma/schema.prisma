// ==========================================
// PAYMENT GATEWAY MODELS
// ==========================================

enum PaymentProviderType {
  ESEWA
  FONEPAY
  CONNECTIPS
  STRIPE
  PAYPAL
  KHALTI
  IME_PAY
}

enum PaymentProviderStatus {
  ACTIVE
  INACTIVE
  TEST_MODE
}

enum PaymentTransactionStatus {
  INITIATED
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
  PARTIAL_REFUND
  AMBIGUOUS
  EXPIRED
}

enum PaymentTransactionType {
  PAYMENT
  REFUND
  CHARGEBACK
}

model PaymentProvider {
  id        String                @id @default(uuid())
  tenant    Tenant?               @relation(fields: [tenantId], references: [id])
  tenantId  String? // null = platform-level provider
  name      String // Display name: "eSewa", "Fonepay", etc.
  type      PaymentProviderType
  status    PaymentProviderStatus @default(INACTIVE)
  isDefault Boolean               @default(false)

  // Credentials stored encrypted (JSON)
  credentials Json // { merchantId, secretKey, ... }

  // Provider-specific config
  config Json? // { sandbox: true, callbackUrl: "...", ... }

  // Fee structure
  transactionFeePercent Decimal? @db.Decimal(5, 2)
  fixedFee              Decimal? @db.Decimal(10, 2)

  // Supported currencies
  supportedCurrencies String[] @default(["NPR"])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions PaymentTransaction[]

  @@unique([tenantId, type])
  @@index([tenantId])
  @@index([type])
  @@index([status])
}

model PaymentTransaction {
  id         String          @id @default(uuid())
  tenant     Tenant?         @relation(fields: [tenantId], references: [id])
  tenantId   String?
  provider   PaymentProvider @relation(fields: [providerId], references: [id])
  providerId String

  // Transaction identifiers
  internalOrderId String // Our internal order/invoice reference
  providerTxnId   String? // Provider's transaction ID (eSewa ref_id, Fonepay UID, etc.)

  // Amount details
  amount    Decimal  @db.Decimal(15, 2)
  currency  String   @default("NPR")
  fee       Decimal? @db.Decimal(10, 2)
  netAmount Decimal? @db.Decimal(15, 2)

  // Status
  type   PaymentTransactionType   @default(PAYMENT)
  status PaymentTransactionStatus @default(INITIATED)

  // Payment details
  paymentMethod String? // eSewa, Fonepay QR, card, bank transfer, etc.
  description   String?

  // Customer info
  customerEmail String?
  customerPhone String?
  customerName  String?

  // Provider-specific data
  providerRequest  Json? // What we sent to provider
  providerResponse Json? // What provider returned

  // Redirect URLs
  successUrl  String?
  failureUrl  String?
  cancelUrl   String?
  callbackUrl String? // Server-to-server callback

  // Verification
  verifiedAt DateTime?
  verifiedBy String? // "callback", "manual", "webhook"

  // Refund info
  refundedAmount Decimal? @db.Decimal(15, 2)
  refundReason   String?

  // Metadata
  metadata  Json? // Additional custom data
  ipAddress String?
  userAgent String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime?

  @@unique([internalOrderId])
  @@index([tenantId])
  @@index([providerId])
  @@index([internalOrderId])
  @@index([providerTxnId])
  @@index([status])
  @@index([createdAt])
}

// =====================================================
// BLOG MANAGEMENT MODELS
// =====================================================

enum BlogStatus {
  draft
  published
  scheduled
  archived
}

enum CommentStatus {
  pending
  approved
  rejected
  spam
}

model Blog {
  id            String     @id @default(uuid())
  title         String
  slug          String     @unique
  content       String
  excerpt       String?
  featuredImage String?
  template      String     @default("standard") // standard | feature | minimal
  status        BlogStatus @default(draft)
  publishedAt   DateTime?
  scheduledAt   DateTime?

  // Relations
  author     User          @relation("BlogAuthor", fields: [authorId], references: [id])
  authorId   String
  category   BlogCategory? @relation(fields: [categoryId], references: [id])
  categoryId String?

  // Tenant scoping (null = platform blog)
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  tenantId String?

  // SEO
  metaTitle       String?
  metaDescription String?

  // Stats
  viewCount Int @default(0)
  likeCount Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  comments BlogComment[]
  tags     BlogTag[]

  @@index([tenantId])
  @@index([authorId])
  @@index([categoryId])
  @@index([status])
  @@index([slug])
}

model BlogCategory {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?
  color       String?
  icon        String?
  thumbnail   String?

  // Tenant scoping (null = platform category)
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  tenantId String?

  // Hierarchy
  parent   BlogCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  parentId String?
  children BlogCategory[] @relation("CategoryHierarchy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blogs Blog[]

  @@index([tenantId])
  @@index([slug])
}

model BlogComment {
  id      String        @id @default(uuid())
  content String
  status  CommentStatus @default(pending)

  // Relations
  blog     Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)
  blogId   String
  author   User   @relation("CommentAuthor", fields: [authorId], references: [id])
  authorId String

  // For guest comments (optional)
  guestName  String?
  guestEmail String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([blogId])
  @@index([authorId])
  @@index([status])
}

model BlogTag {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  // Tenant scoping (null = platform tag)
  tenantId String?

  createdAt DateTime @default(now())

  blogs Blog[]

  @@index([tenantId])
}

// Per-tenant (or platform when tenantId is null) CRM channel integration config
model ChannelConfig {
  id            String  @id @default(uuid())
  tenantId      String? // null = platform-level config
  channel       String // WHATSAPP | TIKTOK | INSTAGRAM | FACEBOOK | EMAIL | WEBSITE | VIBER | SMS
  enabled       Boolean @default(true)
  webhookSecret String?
  credentials   Json? // channel-specific keys/tokens/phone numbers
  displayName   String?

