datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum TenantStatus {
  active
  suspended
  trial
  cancelled
}

enum UserStatus {
  active
  inactive
  pending_verification
  locked
}

enum BillingInterval {
  monthly
  yearly
}

enum SubscriptionStatus {
  active
  trial
  past_due
  canceled
  unpaid
}

enum NotificationType {
  email
  sms
  push
  inApp
}

enum DomainType {
  FITNESS_CENTER
  SALON_AND_SPA
  SCHOOL_AND_EDUCATION
  COACHING_INSTITUTE
  RESTAURANT_AND_CAFE
  HOTEL_AND_HOSPITALITY
  HEALTHCARE_CLINIC
  ECOMMERCE
  LOGISTICS_AND_DELIVERY
  TAILOR_SHOP
  NGO
  SME_CORPORATE
}

model Domain {
  id             String             @id @default(uuid())
  name           String
  code           DomainType         @unique
  description    String?
  modulesEnabled Json // Array of module codes enabled by default
  theme          String             @default("default")
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  modules        DomainModule[]
  roles          DomainRole[]
  permissions    DomainPermission[]
  menus          DomainMenu[]
  widgets        DomainWidget[]
  themes         DomainTheme[]
  tenantDomains  TenantDomain[]
}

model DomainModule {
  id          String                @id @default(uuid())
  domain      Domain                @relation(fields: [domainId], references: [id])
  domainId    String
  code        String                @unique // fitness_members, salon_appointments, etc.
  name        String
  description String?
  category    String // MEMBERS, OPERATIONS, FINANCE, COMMERCE, etc.
  icon        String?
  route       String? // React route: /members, /appointments, etc.
  isCore      Boolean               @default(true) // Core vs optional module
  sortOrder   Int                   @default(0)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  permissions DomainPermission[]
  menus       DomainMenu[]
  widgets     DomainWidget[]
  enabledBy   TenantEnabledModule[]

  @@index([domainId])
  @@index([code])
}

model DomainRole {
  id          String             @id @default(uuid())
  domain      Domain             @relation(fields: [domainId], references: [id])
  domainId    String
  name        String
  code        String // owner, manager, trainer, customer, etc.
  description String?
  isDefault   Boolean            @default(false)
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  permissions DomainPermission[]
  menus       DomainMenu[]
  widgets     DomainWidget[]

  @@unique([domainId, code])
  @@index([domainId])
}

model DomainPermission {
  id        String       @id @default(uuid())
  domain    Domain       @relation(fields: [domainId], references: [id])
  domainId  String
  module    DomainModule @relation(fields: [moduleId], references: [id])
  moduleId  String
  role      DomainRole   @relation(fields: [roleId], references: [id])
  roleId    String
  action    String // view, create, edit, delete, manage
  createdAt DateTime     @default(now())

  @@unique([domainId, moduleId, roleId, action])
  @@index([domainId])
  @@index([moduleId])
  @@index([roleId])
}

model DomainMenu {
  id           String       @id @default(uuid())
  domain       Domain       @relation(fields: [domainId], references: [id])
  domainId     String
  parent       DomainMenu?  @relation("MenuHierarchy", fields: [parentId], references: [id])
  parentId     String?
  children     DomainMenu[] @relation("MenuHierarchy")
  code         String // dashboard, members, appointments, etc.
  label        String
  icon         String?
  route        String?
  module       DomainModule @relation(fields: [moduleId], references: [id])
  moduleId     String
  role         DomainRole?  @relation(fields: [roleId], references: [id])
  roleId       String?
  sortOrder    Int          @default(0)
  isPublic     Boolean      @default(false)
  isVisible    Boolean      @default(true)
  requiredPlan String? // starter, professional, enterprise
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([domainId, code])
  @@index([domainId, sortOrder])
  @@index([moduleId])
}

model DomainWidget {
  id              String       @id @default(uuid())
  domain          Domain       @relation(fields: [domainId], references: [id])
  domainId        String
  code            String // today_attendance, active_members, revenue, etc.
  name            String
  description     String?
  category        String // DASHBOARD, REPORTS, ANALYTICS, etc.
  icon            String?
  component       String // React component path
  config          Json? // Widget-specific configuration
  module          DomainModule @relation(fields: [moduleId], references: [id])
  moduleId        String
  role            DomainRole?  @relation(fields: [roleId], references: [id])
  roleId          String?
  isVisible       Boolean      @default(true)
  refreshInterval Int? // seconds
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([domainId, code])
  @@index([domainId])
  @@index([moduleId])
}

model DomainTheme {
  id                String   @id @default(uuid())
  domain            Domain   @relation(fields: [domainId], references: [id])
  domainId          String
  name              String
  code              String   @unique // fitness_theme, salon_theme, etc.
  primaryColor      String   @default("#007bff")
  secondaryColor    String   @default("#6c757d")
  backgroundColor   String   @default("#ffffff")
  textColor         String   @default("#212529")
  logoUrl           String?
  primaryFont       String   @default("system-ui, -apple-system, sans-serif")
  dashboardTemplate Json // Layout configuration
  websiteTemplate   Json // Landing page configuration
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([domainId, isActive])
  @@index([code])
}

model TenantDomain {
  id         String   @id @default(uuid())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  tenantId   String
  domain     Domain   @relation(fields: [domainId], references: [id])
  domainId   String
  assignedAt DateTime @default(now())
  isActive   Boolean  @default(true)

  @@unique([tenantId, domainId])
  @@index([tenantId])
  @@index([domainId])
}

model TenantEnabledModule {
  id         String       @id @default(uuid())
  tenant     Tenant       @relation(fields: [tenantId], references: [id])
  tenantId   String
  module     DomainModule @relation(fields: [moduleId], references: [id])
  moduleId   String
  isEnabled  Boolean      @default(true)
  settings   Json? // Module-specific settings
  assignedAt DateTime     @default(now())

  @@unique([tenantId, moduleId])
  @@index([tenantId])
  @@index([moduleId])
}

model Tenant {
  id                     String                  @id @default(uuid())
  name                   String
  subdomain              String?                 @unique
  domain                 String?
  status                 TenantStatus            @default(active)
  plan                   Plan?                   @relation(fields: [planId], references: [id])
  planId                 String?
  settings               Json?
  users                  User[]
  roles                  Role[]
  subscriptions          Subscription[]
  auditLogs              AuditLog[]
  files                  File[]
  permissions            Permission[]
  notificationTemplates  NotificationTemplate[]
  tenantSettings         Setting[]
  // Domain-driven tenant architecture
  domains                TenantDomain[]
  enabledModules         TenantEnabledModule[]
  // Finance module relations
  chartOfAccounts        ChartOfAccount[]
  fiscalYears            FiscalYear[]
  accountingPeriods      AccountingPeriod[]
  journalEntries         JournalEntry[]
  journalEntryLines      JournalEntryLine[]
  masterBills            MasterBill[]
  customers              Customer[]
  suppliers              Supplier[]
  bankAccounts           BankAccount[]
  reprintLogs            ReprintLog[]
  financeAuditLogs       FinanceAuditLog[]
  invoices               Invoice[]
  invoiceItems           InvoiceItem[]
  bills                  Bill[]
  paymentsReceived       PaymentReceived[]
  paymentsMade           PaymentMade[]
  paymentAllocations     PaymentAllocation[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  trialEndsAt            DateTime?
  createdBy              String?
  // Globalization relations
  languages              TenantLanguage[]
  currencies             TenantCurrency[]
  taxRates               TaxRate[]
  taxGroups              TaxGroup[]
  coupons                Coupon[]
  marketingCampaigns     MarketingCampaign[]
  leads                  Lead[]
  brandAssets            BrandAsset[]
  brandGuidelines        BrandGuideline[]
  brandVoice             BrandVoice?
  paymentProviders       PaymentProvider[]
  paymentTransactions    PaymentTransaction[]
  // Multi-Branch & OAuth relations
  branches               Branch[]
  oauthConfigs           TenantOAuthConfig[]
  // Blog relations
  blogs                  Blog[]
  blogCategories         BlogCategory[]
  contactMessages        ContactMessage[]
  whatsappConfig         TenantWhatsAppConfig?
  // v5 onboarding + lifecycle
  customerOnboardings    CustomerOnboarding[]
  tenantOnboarding       TenantOnboarding?
  tenantLifecycle        TenantLifecycle?
  // Fitness domain relations
  members                Member[]
  trainers               Trainer[]
  workouts               Workout[]
  trainingSessions       TrainingSession[]
  // Salon domain relations
  appointments           Appointment[]
  stylists               Stylist[]
  services               Service[]
  // School domain relations
  students               Student[]
  teachers               Teacher[]
  classes                Class[]
  enrollments            Enrollment[]
  exams                  Exam[]
  examResults            ExamResult[]
  // FitNepal fitness domain relations
  membershipPlans        MembershipPlan[]
  memberships            Membership[]
  bodyAssessments        BodyAssessment[]
  workoutPlans           WorkoutPlan[]
  workoutDays            WorkoutDay[]
  workoutExercises       WorkoutExercise[]
  workoutLogs            WorkoutLog[]
  exerciseLogs           ExerciseLog[]
  dietPlans              DietPlan[]
  dietMeals              DietMeal[]
  foodLogs               FoodLog[]
  attendances            Attendance[]
  reminderLogs           ReminderLog[]
  groupClasses           GroupClass[]
  classBookings          ClassBooking[]
  trainerMessages        TrainerMessage[]
  badges                 Badge[]
  customerBadges         CustomerBadge[]
  referrals              Referral[]
  equipment              Equipment[]
  equipmentMaintenance   EquipmentMaintenance[]
  // Biometric attendance (ZKTeco) relations
  attendanceDevices      AttendanceDevice[]
  attendancePullSessions AttendancePullSession[]
  // Ecommerce domain relations
  productCategories      ProductCategory[]
  brands                 Brand[]
  products               Product[]
  warehouses             Warehouse[]
  stockItems             StockItem[]
  stockLedgerEntries     StockLedgerEntry[]
  carts                  Cart[]
  salesOrders            SalesOrder[]
  shipments              Shipment[]
  productAttributes      ProductAttribute[]
  webhookEndpoints       WebhookEndpoint[]
  moduleOverrides        TenantModuleOverride[]
  aiInteractionLogs      AiInteractionLog[]
  chatwootConfig         TenantChatwootConfig?

  @@index([subdomain])
  @@index([domain])
  @@index([status])
}

model User {
  id                      String               @id @default(uuid())
  tenant                  Tenant?              @relation(fields: [tenantId], references: [id])
  tenantId                String?
  email                   String               @unique
  passwordHash            String?
  firstName               String?
  lastName                String?
  phone                   String?
  avatarUrl               String?
  status                  UserStatus           @default(active)
  emailVerified           Boolean              @default(false)
  isPlatformAdmin         Boolean              @default(false)
  mfaEnabled              Boolean              @default(false)
  mfaSecret               String?
  recoveryCodes           String?
  failedLoginCount        Int                  @default(0)
  lockedUntil             DateTime?
  refreshTokens           RefreshToken[]
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  lastLoginAt             DateTime?
  userRoles               UserRoles[]          @relation("userRoles")
  auditLogs               AuditLog[]
  files                   File[]
  invitedBy               User?                @relation("Invitations", fields: [invitedById], references: [id])
  invitedById             String?
  invitationToken         String?
  invitationExpiresAt     DateTime?
  invitedUsers            User[]               @relation("Invitations")
  assignedUserRoles       UserRoles[]          @relation("AssignedBy")
  assignedLeads           Lead[]
  assignedContactMessages ContactMessage[]
  voucherRedemptions      VoucherRedemption[]
  couponRedemptions       CouponRedemption[]
  oauthAccounts           OAuthAccount[]
  branchUsers             BranchUser[]
  // Blog relations
  blogs                   Blog[]               @relation("BlogAuthor")
  blogComments            BlogComment[]        @relation("CommentAuthor")
  // Domain-specific relations (one-to-many since user can have roles across tenants)
  members                 Member[]
  trainers                Trainer[]
  stylists                Stylist[]
  students                Student[]
  teachers                Teacher[]
  appointmentCustomer     Appointment[]        @relation("AppointmentCustomer")
  // v5 onboarding
  customerOnboardings     CustomerOnboarding[]

  @@index([tenantId])
  @@index([email])
  @@index([status])
}

// Rotating refresh tokens (hashed); revocation = logout/blacklist
model RefreshToken {
  id           String    @id @default(uuid())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  tokenHash    String    @unique // sha256 of the token
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String? // rotation chain; reuse of a replaced token = theft signal
  userAgent    String?
  ip           String?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// =====================================================
// MARKETPLACE
// =====================================================

enum MarketplaceItemType {
  template // website/domain template
  plugin // functional add-on module
}

enum MarketplaceItemStatus {
  draft
  published
  archived
}

model MarketplaceItem {
  id          String                @id @default(uuid())
  type        MarketplaceItemType   @default(template)
  name        String
  slug        String                @unique
  description String?
  longDescription String?
  category    String? // e.g. fitness, restaurant, general
  domainType  String? // target domain vertical, null = any
  thumbnail   String?
  screenshots Json? // string[]
  priceCents  Int                   @default(0) // 0 = free
  currency    String                @default("NPR")
  version     String                @default("1.0.0")
  authorName  String                @default("Dexo Platform")
  features    Json? // string[] of feature bullets / module keys enabled
  config      Json? // template payload / plugin manifest
  status      MarketplaceItemStatus @default(draft)
  installCount Int                  @default(0)
  ratingAvg   Float                 @default(0)
  ratingCount Int                   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  installs MarketplaceInstall[]
  reviews  MarketplaceReview[]

  @@index([type, status])
  @@index([category])
  @@index([domainType])
}

model MarketplaceInstall {
  id       String          @id @default(uuid())
  item     MarketplaceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId   String
  tenantId String
  status   String          @default("installed") // installed | disabled | uninstalled
  settings Json?

  installedAt   DateTime  @default(now())
  uninstalledAt DateTime?

  @@unique([itemId, tenantId])
  @@index([tenantId])
}

model MarketplaceReview {
  id       String          @id @default(uuid())
  item     MarketplaceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId   String
  tenantId String?
  userId   String?
  rating   Int // 1-5
  comment  String?

  createdAt DateTime @default(now())

  @@unique([itemId, userId])
  @@index([itemId])
}

// =====================================================
// OAUTH / SOCIAL LOGIN MODELS
// =====================================================

enum OAuthProvider {
  google
  github
  apple
  facebook
  microsoft
  linkedin
}

model OAuthAccount {
  id               String        @id @default(uuid())
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  provider         OAuthProvider
  providerUserId   String // User ID from OAuth provider
  providerEmail    String?
  providerUsername String?
  providerAvatar   String?
  accessToken      String? // Encrypted
  refreshToken     String? // Encrypted
  tokenExpiresAt   DateTime?
  scope            String?
  idToken          String? // For OIDC providers
  rawProfile       Json? // Full profile from provider
  isPrimary        Boolean       @default(false) // Is this the primary auth method
  tenantId         String? // Optional tenant binding for tenant-level OAuth
  lastUsedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([provider])
  @@index([tenantId])
}

model TenantOAuthConfig {
  id             String        @id @default(uuid())
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId       String
  provider       OAuthProvider
  clientId       String
  clientSecret   String? // Encrypted
  redirectUri    String
  scope          String?
  isEnabled      Boolean       @default(true)
  autoCreateUser Boolean       @default(false) // Auto-create user on first OAuth login
  defaultRoleId  String? // Role assigned to auto-created users
  allowedDomains String? // Comma-separated email domains allowed
  customBranding Json? // Provider-specific branding
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@index([provider])
}

model PlatformOAuthConfig {
  id           String        @id @default(uuid())
  provider     OAuthProvider @unique
  clientId     String
  clientSecret String? // Encrypted
  redirectUri  String
  scope        String?
  isEnabled    Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// =====================================================
// WHATSAPP BUSINESS INTEGRATION (4.2)
// =====================================================

model TenantWhatsAppConfig {
  id                 String   @id @default(uuid())
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId           String
  phoneNumber        String // E.164 format: 9779800000000 (no +)
  displayName        String? // Business name shown in WhatsApp profile
  // Meta Cloud API credentials (TODO: rotate secrets + encrypt at rest)
  accessToken        String? // Meta Cloud API access token (system user token)
  phoneNumberId      String? // Meta Cloud API phone_number_id
  wabaId             String? // WhatsApp Business Account ID
  webhookVerifyToken String? // Token used to verify webhook subscription
  // Feature flags
  isEnabled          Boolean  @default(false)
  autoReplyEnabled   Boolean  @default(false) // Auto-reply to inbound messages (TODO)
  // Template messages (JSON keyed by notification type, e.g. { "membership_expiry": "membership_expiry_template" })
  templates          Json?
  // Opt-out list (comma-separated phone numbers) — Meta policy compliance
  optOutList         String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([tenantId])
  @@index([tenantId])
  @@index([phoneNumber])
}

// =====================================================
// MULTI-BRANCH MODELS
// =====================================================

model Branch {
  id             String    @id @default(uuid())
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantId       String
  code           String // Branch code/SKU
  name           String
  slug           String? // For subdomain-based branch access
  type           String? // HQ, BRANCH, FRANCHISE, POPUP
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  country        String?
  postalCode     String?
  latitude       Decimal?  @db.Decimal(10, 7)
  longitude      Decimal?  @db.Decimal(10, 7)
  timezone       String?   @default("UTC")
  currency       String?   @default("NPR")
  managerId      String? // Branch manager user ID
  status         String    @default("active") // active, inactive, closed
  settings       Json? // Branch-specific settings
  operatingHours Json? // Operating hours per day
  isHeadquarters Boolean   @default(false)
  openedAt       DateTime?
  closedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  branchUsers       BranchUser[]
  invoices          Invoice[]
  paymentsReceived  PaymentReceived[]
  paymentsMade      PaymentMade[]
  customers         Customer[]
  bankAccounts      BankAccount[]
  journalEntries    JournalEntry[]
  reports           BranchReport[]
  expenses          BranchExpense[]
  schedules         BranchSchedule[]
  attendances       Attendance[]
  // FitNepal fitness relations
  groupClasses      GroupClass[]
  equipment         Equipment[]
  members           Member[]
  trainers          Trainer[]
  attendanceDevices AttendanceDevice[]
  warehouses        Warehouse[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([slug])
  @@index([status])
  @@index([type])
}

model BranchUser {
  id          String    @id @default(uuid())
  branch      Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  branchId    String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  role        String // BRANCH_MANAGER, TRAINER, STAFF, MEMBER
  isPrimary   Boolean   @default(false) // User's primary branch
  startDate   DateTime  @default(now())
  endDate     DateTime?
  isActive    Boolean   @default(true)
  permissions Json? // Branch-specific permissions
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([branchId, userId, role])
  @@index([branchId])
  @@index([userId])
  @@index([role])
  @@index([isActive])
}

model BranchSchedule {
  id        String   @id @default(uuid())
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  branchId  String
  userId    String? // Employee/trainer
  className String?
  startTime DateTime
  endTime   DateTime
  type      String // CLASS, APPOINTMENT, SHIFT
  status    String   @default("scheduled")
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@index([userId])
  @@index([startTime])
  @@index([type])
}

model Attendance {
  id           String            @id @default(uuid())
  branch       Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  branchId     String
  userId       String
  customerId   String? // For member check-ins
  type         String // MEMBER_CHECKIN, STAFF_CLOCKIN, CLASS
  checkInTime  DateTime
  checkOutTime DateTime?
  duration     Int? // minutes
  status       String            @default("present")
  notes        String?
  memberId     String?
  member       Member?           @relation(fields: [memberId], references: [id])
  membershipId String?
  membership   Membership?       @relation(fields: [membershipId], references: [id])
  method       AttendanceMethod? @default(QR_CODE)
  tenantId     String?
  tenant       Tenant?           @relation(fields: [tenantId], references: [id])
  // Biometric device punch source (ZKTeco puller)
  deviceId     String?
  device       AttendanceDevice? @relation(fields: [deviceId], references: [id])
  deviceUid    String? // user id on the device
  createdAt    DateTime          @default(now())

  @@unique([deviceId, deviceUid, checkInTime])
  @@index([branchId])
  @@index([userId])
  @@index([customerId])
  @@index([checkInTime])
  @@index([type])
  @@index([memberId])
  @@index([tenantId])
}

model BranchReport {
  id          String   @id @default(uuid())
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  branchId    String
  reportType  String // DAILY_SALES, MONTHLY_REVENUE, STAFF_PERFORMANCE, etc.
  period      String // YYYY-MM, YYYY-MM-DD, YYYY-Q1
  data        Json
  generatedAt DateTime @default(now())
  generatedBy String? // userId

  @@unique([branchId, reportType, period])
  @@index([branchId])
  @@index([reportType])
  @@index([period])
}

model BranchExpense {
  id          String   @id @default(uuid())
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  branchId    String
  category    String // RENT, UTILITIES, SALARY, SUPPLIES, etc.
  description String
  amount      Decimal  @db.Decimal(15, 2)
  currency    String   @default("NPR")
  expenseDate DateTime
  approvedBy  String?
  receiptUrl  String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([branchId])
  @@index([category])
  @@index([expenseDate])
  @@index([status])
}

model Role {
  id          String      @id @default(uuid())
  tenant      Tenant?     @relation(fields: [tenantId], references: [id])
  tenantId    String?
  name        String
  description String?
  isSystem    Boolean     @default(false)
  permissions Json?
  userRoles   UserRoles[] @relation("roleRoles")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([tenantId])
}

model Permission {
  id          String   @id @default(uuid())
  resource    String
  action      String
  description String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  tenantId    String?
  createdAt   DateTime @default(now())

  @@unique([resource, action, tenantId])
  @@index([tenantId])
}

model UserRoles {
  user         User     @relation("userRoles", fields: [userId], references: [id])
  userId       String
  role         Role     @relation("roleRoles", fields: [roleId], references: [id])
  roleId       String
  assignedBy   User?    @relation("AssignedBy", fields: [assignedById], references: [id])
  assignedById String?
  assignedAt   DateTime @default(now())

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model Plan {
  id                    String          @id @default(uuid())
  name                  String
  slug                  String          @unique
  description           String?
  priceCents            Int
  pricePerCustomerCents Int             @default(0)
  currency              String          @default("USD")
  billingInterval       BillingInterval @default(monthly)
  maxCustomers          Int             @default(9999)
  maxUsers              Int             @default(50)
  maxBranches           Int             @default(10)
  trialDays             Int             @default(30)
  isFeatured            Boolean         @default(false)
  features              Json?
  limits                Json?
  isActive              Boolean         @default(true)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  subscriptions         Subscription[]
  tenants               Tenant[]

  @@index([slug])
  @@index([isActive])
}

model Subscription {
  id                 String             @id @default(uuid())
  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  tenantId           String
  plan               Plan               @relation(fields: [planId], references: [id])
  planId             String
  status             SubscriptionStatus @default(trial)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialStart         DateTime?
  trialEnd           DateTime?
  canceledAt         DateTime?
  endedAt            DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([tenantId])
  @@index([planId])
  @@index([status])
}

model AuditLog {
  id           String   @id @default(uuid())
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  tenantId     String?
  user         User?    @relation(fields: [userId], references: [id])
  userId       String?
  action       String
  resourceType String?
  resourceId   String?
  changes      Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

/// Every unhandled exception the API's global CentralErrorFilter catches —
/// written here regardless of how the API process was started (npm run dev,
/// run.bat, PM2, ...), so a crash is visible in platform-admin even if
/// nobody was watching the terminal it happened in. Deliberately NOT a
/// relation to Tenant/User (plain string ids) since the error itself may be
/// caused by an invalid/deleted tenantId — a broken FK must never prevent
/// logging the error that reports it.
model ErrorLog {
  id         String   @id @default(uuid())
  method     String
  path       String
  statusCode Int
  message    String   @db.Text
  errorName  String?
  stack      String?  @db.Text
  tenantId   String?
  userId     String?
  requestId  String?
  createdAt  DateTime @default(now())

  @@index([statusCode])
  @@index([createdAt])
  @@index([tenantId])
}

model NotificationTemplate {
  id        String           @id @default(uuid())
  tenant    Tenant?          @relation(fields: [tenantId], references: [id])
  tenantId  String?
  name      String
  type      NotificationType
  subject   String?
  body      String
  variables Json?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([tenantId])
  @@index([type])
}

enum FileScope {
  PLATFORM
  TENANT
}

enum FileDocumentType {
  LOGO
  PROFILE_PIC
  DOCUMENT
  INVOICE
  CONTRACT
  ID_PROOF
  OTHER
}

model File {
  id           String           @id @default(uuid())
  // PLATFORM-scoped files (e.g. the platform's own logo) have no tenant —
  // TENANT-scoped files always do. See files.validation.ts for the
  // allowed-type/max-size rules enforced per documentType at upload time.
  scope        FileScope        @default(TENANT)
  tenant       Tenant?          @relation(fields: [tenantId], references: [id])
  tenantId     String?
  user         User?            @relation(fields: [userId], references: [id])
  userId       String?
  documentType FileDocumentType @default(OTHER)
  s3Key        String
  originalName String
  mimeType     String?
  sizeBytes    BigInt?
  isPublic     Boolean          @default(false)
  uploadedAt   DateTime         @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([s3Key])
  @@index([scope])
  @@index([documentType])
}

model Setting {
  id        String   @id @default(uuid())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  tenantId  String?
  key       String
  value     Json
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId])
}

// =============================================
// FINANCE MODULE - ACCOUNTING & INVOICING
// =============================================

model ChartOfAccount {
  id            String           @id @default(uuid())
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  tenantId      String
  accountCode   String
  accountName   String
  accountType   String // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE, COGS
  parent        ChartOfAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  parentId      String?
  children      ChartOfAccount[] @relation("AccountHierarchy")
  isControl     Boolean          @default(false)
  currency      String           @default("NPR")
  normalBalance String // DEBIT or CREDIT
  isActive      Boolean          @default(true)
  createdBy     String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  journalEntryLines JournalEntryLine[]
  invoiceItems      InvoiceItem[]

  @@unique([tenantId, accountCode])
  @@index([tenantId])
  @@index([accountCode])
}

model FiscalYear {
  id        String    @id @default(uuid())
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  tenantId  String
  name      String // e.g., "2081/82"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean   @default(false)
  isClosed  Boolean   @default(false)
  closedBy  String?
  closedAt  DateTime?
  createdAt DateTime  @default(now())

  accountingPeriods AccountingPeriod[]
  journalEntries    JournalEntry[]
  invoices          Invoice[]
  bills             Bill[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model AccountingPeriod {
  id           String     @id @default(uuid())
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  tenantId     String
  fiscalYear   FiscalYear @relation(fields: [fiscalYearId], references: [id])
  fiscalYearId String
  periodName   String // e.g., "Shrawan 2081"
  startDate    DateTime
  endDate      DateTime
  isClosed     Boolean    @default(false)
  closedBy     String?
  closedAt     DateTime?

  journalEntries JournalEntry[]

  @@unique([tenantId, fiscalYearId, startDate])
  @@index([tenantId])
  @@index([fiscalYearId])
}

model JournalEntry {
  id            String           @id @default(uuid())
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  tenantId      String
  branch        Branch?          @relation(fields: [branchId], references: [id])
  branchId      String?
  fiscalYear    FiscalYear       @relation(fields: [fiscalYearId], references: [id])
  fiscalYearId  String
  period        AccountingPeriod @relation(fields: [periodId], references: [id])
  periodId      String
  entryNo       String
  entryDate     DateTime
  referenceType String? // INVOICE, PAYMENT, PAYROLL, MANUAL, REVERSAL
  referenceId   String?
  description   String
  narration     String?
  isPosted      Boolean          @default(false)
  isReversed    Boolean          @default(false)
  reversalOf    JournalEntry?    @relation("ReversalEntries", fields: [reversalOfId], references: [id])
  reversalOfId  String?
  reversals     JournalEntry[]   @relation("ReversalEntries")
  createdBy     String
  createdAt     DateTime         @default(now())
  postedBy      String?
  postedAt      DateTime?

  lines            JournalEntryLine[]
  invoices         Invoice[]
  bills            Bill[]
  paymentsReceived PaymentReceived[]
  paymentsMade     PaymentMade[]

  @@unique([tenantId, entryNo])
  @@index([tenantId])
  @@index([entryDate])
}

model JournalEntryLine {
  id             String         @id @default(uuid())
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  journalEntryId String
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  tenantId       String
  account        ChartOfAccount @relation(fields: [accountId], references: [id])
  accountId      String
  lineNo         Int
  description    String?
  debitAmount    Decimal        @default(0) @db.Decimal(18, 2)
  creditAmount   Decimal        @default(0) @db.Decimal(18, 2)
  currency       String         @default("NPR")

  @@index([journalEntryId])
  @@index([accountId])
}

model MasterBill {
  id              String    @id @default(uuid())
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  tenantId        String
  fiscalYear      String
  billNo          String
  customerName    String?
  customerPan     String?
  billDate        DateTime
  amount          Decimal   @db.Decimal(15, 2)
  discount        Decimal   @default(0) @db.Decimal(15, 2)
  taxableAmount   Decimal   @db.Decimal(15, 2)
  taxAmount       Decimal   @db.Decimal(15, 2)
  totalAmount     Decimal   @db.Decimal(15, 2)
  syncWithIrd     Boolean   @default(false)
  isBillPrinted   Boolean   @default(false)
  isBillActive    Boolean   @default(true)
  printedTime     DateTime?
  enteredBy       String
  printedBy       String?
  isRealtime      Boolean   @default(true)
  paymentMethod   String?
  vatRefundAmount Decimal?  @db.Decimal(15, 2)
  transactionId   String?
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id])
  invoiceId       String?
  createdAt       DateTime  @default(now())

  @@unique([tenantId, fiscalYear, billNo])
  @@index([tenantId])
  @@index([syncWithIrd])
}

model Invoice {
  id             String        @id @default(uuid())
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  tenantId       String
  branch         Branch?       @relation(fields: [branchId], references: [id])
  branchId       String?
  masterBills    MasterBill[]
  fiscalYear     FiscalYear    @relation(fields: [fiscalYearId], references: [id])
  fiscalYearId   String
  invoiceNumber  String
  invoiceType    String // TAX_INVOICE, ABBREVIATED, INVOICE, CREDIT_NOTE, DEBIT_NOTE
  invoiceDate    DateTime
  dueDate        DateTime?
  customer       Customer      @relation(fields: [customerId], references: [id])
  customerId     String
  customerPan    String?
  billingAddress String?
  subtotal       Decimal       @db.Decimal(15, 2)
  discountAmount Decimal       @default(0) @db.Decimal(15, 2)
  taxableAmount  Decimal       @db.Decimal(15, 2)
  vatAmount      Decimal       @default(0) @db.Decimal(15, 2)
  totalAmount    Decimal       @db.Decimal(15, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(15, 2)
  paymentStatus  String        @default("UNPAID") // UNPAID, PARTIAL, PAID, CANCELLED
  currency       String        @default("NPR")
  notes          String?
  isActive       Boolean       @default(true)
  cancelledAt    DateTime?
  cancelledBy    String?
  cancelReason   String?
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  journalEntryId String?
  createdBy      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items              InvoiceItem[]
  reprintLogs        ReprintLog[]
  paymentAllocations PaymentAllocation[]
  salesOrder         SalesOrder?

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([customerId])
  @@index([paymentStatus])
}

model InvoiceItem {
  id             String          @id @default(uuid())
  invoice        Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId      String
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  tenantId       String
  itemNo         Int
  description    String
  quantity       Decimal         @db.Decimal(10, 3)
  unitOfMeasure  String?
  unitPrice      Decimal         @db.Decimal(15, 2)
  discountPct    Decimal         @default(0) @db.Decimal(5, 2)
  discountAmount Decimal         @default(0) @db.Decimal(15, 2)
  taxableAmount  Decimal         @db.Decimal(15, 2)
  vatRate        Decimal         @default(13.00) @db.Decimal(5, 2)
  vatAmount      Decimal         @default(0) @db.Decimal(15, 2)
  totalAmount    Decimal         @db.Decimal(15, 2)
  account        ChartOfAccount? @relation(fields: [accountId], references: [id])
  accountId      String?

  @@index([invoiceId])
}

model Bill {
  id             String        @id @default(uuid())
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  tenantId       String
  fiscalYear     FiscalYear    @relation(fields: [fiscalYearId], references: [id])
  fiscalYearId   String
  billNumber     String
  billType       String        @default("PURCHASE") // PURCHASE, DEBIT_NOTE
  billDate       DateTime
  dueDate        DateTime?
  supplier       Supplier      @relation(fields: [supplierId], references: [id])
  supplierId     String
  supplierPan    String?
  subtotal       Decimal       @db.Decimal(15, 2)
  discountAmount Decimal       @default(0) @db.Decimal(15, 2)
  taxableAmount  Decimal       @db.Decimal(15, 2)
  vatAmount      Decimal       @default(0) @db.Decimal(15, 2)
  totalAmount    Decimal       @db.Decimal(15, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(15, 2)
  paymentStatus  String        @default("UNPAID")
  currency       String        @default("NPR")
  notes          String?
  isActive       Boolean       @default(true)
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  journalEntryId String?
  createdBy      String
  createdAt      DateTime      @default(now())

  @@unique([tenantId, billNumber])
  @@index([tenantId])
  @@index([supplierId])
}

model PaymentReceived {
  id              String        @id @default(uuid())
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  tenantId        String
  branch          Branch?       @relation(fields: [branchId], references: [id])
  branchId        String?
  paymentNo       String
  paymentDate     DateTime
  customer        Customer      @relation(fields: [customerId], references: [id])
  customerId      String
  amount          Decimal       @db.Decimal(15, 2)
  paymentMethod   String // CASH, CHEQUE, ESEWA, KHALTI, CONNECTIPS, CARD, BANK_TRANSFER
  referenceNo     String?
  transactionId   String?
  bankAccount     BankAccount?  @relation("BankSource", fields: [bankAccountId], references: [id])
  bankAccountId   String?
  notes           String?
  vatRefundAmount Decimal?      @db.Decimal(15, 2)
  isRefunded      Boolean       @default(false)
  journalEntry    JournalEntry? @relation(fields: [journalEntryId], references: [id])
  journalEntryId  String?
  createdBy       String
  createdAt       DateTime      @default(now())

  allocations PaymentAllocation[]

  @@unique([tenantId, paymentNo])
  @@index([tenantId])
  @@index([customerId])
  @@index([branchId])
}

model PaymentAllocation {
  id              String          @id @default(uuid())
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  tenantId        String
  payment         PaymentReceived @relation(fields: [paymentId], references: [id])
  paymentId       String
  invoice         Invoice         @relation(fields: [invoiceId], references: [id])
  invoiceId       String
  allocatedAmount Decimal         @db.Decimal(15, 2)
  createdAt       DateTime        @default(now())

  @@unique([paymentId, invoiceId])
  @@index([paymentId])
  @@index([invoiceId])
}

model PaymentMade {
  id             String        @id @default(uuid())
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  tenantId       String
  branch         Branch?       @relation(fields: [branchId], references: [id])
  branchId       String?
  paymentNo      String
  paymentDate    DateTime
  paymentType    String // SUPPLIER, SALARY, TRAINER_WAGE, TAX, UTILITY
  payeeType      String // SUPPLIER, EMPLOYEE, CONTRACTOR, TAX_AUTHORITY
  payeeId        String
  amount         Decimal       @db.Decimal(15, 2)
  tdsAmount      Decimal       @default(0) @db.Decimal(15, 2)
  netAmount      Decimal       @db.Decimal(15, 2)
  paymentMethod  String
  referenceNo    String?
  bankAccount    BankAccount?  @relation("BankSource", fields: [bankAccountId], references: [id])
  bankAccountId  String?
  notes          String?
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id])
  journalEntryId String?
  createdBy      String
  createdAt      DateTime      @default(now())

  @@unique([tenantId, paymentNo])
  @@index([tenantId])
  @@index([branchId])
}

model Customer {
  id              String    @id @default(uuid())
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  tenantId        String
  branch          Branch?   @relation(fields: [branchId], references: [id])
  branchId        String?
  customerCode    String?
  name            String
  pan             String?
  mobile          String?
  email           String?
  address         String?
  creditLimit     Decimal   @default(0) @db.Decimal(15, 2)
  isVatRegistered Boolean   @default(false)
  taxGroup        TaxGroup? @relation(fields: [taxGroupId], references: [id])
  taxGroupId      String?
  currentBalance  Decimal   @default(0) @db.Decimal(12, 2)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  invoices         Invoice[]
  paymentsReceived PaymentReceived[]
  carts            Cart[]
  salesOrders      SalesOrder[]

  @@index([tenantId])
}

model Supplier {
  id               String    @id @default(uuid())
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  tenantId         String
  supplierCode     String?
  name             String
  pan              String?
  mobile           String?
  email            String?
  address          String?
  isVatRegistered  Boolean   @default(false)
  paymentTermsDays Int       @default(30)
  taxGroup         TaxGroup? @relation(fields: [taxGroupId], references: [id])
  taxGroupId       String?
  currentBalance   Decimal   @default(0) @db.Decimal(12, 2)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())

  bills Bill[]

  @@index([tenantId])
}

model BankAccount {
  id            String   @id @default(uuid())
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  tenantId      String
  branch        Branch?  @relation(fields: [branchId], references: [id])
  branchId      String?
  accountName   String
  accountNumber String
  bankName      String
  branchName    String?
  accountType   String // SAVINGS, CURRENT, etc.
  currency      String   @default("NPR")
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  paymentsReceivedAsSource PaymentReceived[] @relation("BankSource")
  paymentsMadeAsSource     PaymentMade[]     @relation("BankSource")

  @@index([tenantId])
}

model ReprintLog {
  id         String   @id @default(uuid())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  tenantId   String
  invoice    Invoice  @relation(fields: [invoiceId], references: [id])
  invoiceId  String
  billNo     String
  printType  String // ORIGINAL, COPY
  copyNumber Int      @default(1)
  printedBy  String
  printedAt  DateTime @default(now())
  reason     String?
  ipAddress  String?

  @@index([tenantId])
  @@index([invoiceId])
}

model FinanceAuditLog {
  id        String   @id @default(uuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  tableName String
  recordId  String
  action    String // INSERT, UPDATE, CANCEL, PRINT, REPRINT, SYNC
  oldData   Json?
  newData   Json?
  actionBy  String
  actionAt  DateTime @default(now())
  ipAddress String?
  userAgent String?

  @@index([tenantId])
  @@index([tableName])
  @@index([actionAt])
}

model CbmsSyncQueue {
  id              String    @id @default(uuid())
  tenantId        String
  invoiceId       String
  operation       String // CREATE, CANCEL, UPDATE
  status          String    @default("PENDING") // PENDING, SUCCESS, FAILED, MAX_RETRY
  requestPayload  Json
  responsePayload Json?
  attemptCount    Int       @default(0)
  lastAttemptedAt DateTime?
  nextRetryAt     DateTime?
  errorMessage    String?
  createdAt       DateTime  @default(now())

  @@index([status])
  @@index([nextRetryAt])
}

model BillSequence {
  id         String @id @default(uuid())
  tenantId   String
  fiscalYear String
  billType   String // INV, BILL, CN, DN, JE
  lastNumber Int    @default(0)

  @@unique([tenantId, fiscalYear, billType])
}

// ==========================================
// GLOBALIZATION & LOCALIZATION MODELS
// ==========================================

model Language {
  id         String   @id @default(uuid())
  code       String   @unique // en, ne, hi, etc.
  name       String // English, Nepali, Hindi
  nativeName String? // नेपाली, हिन्दी
  isActive   Boolean  @default(true)
  isRtl      Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenantLanguages TenantLanguage[]
}

model TenantLanguage {
  id         String   @id @default(uuid())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  tenantId   String
  language   Language @relation(fields: [languageId], references: [id])
  languageId String
  isDefault  Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@unique([tenantId, languageId])
  @@index([tenantId])
}

model Currency {
  id            String   @id @default(uuid())
  code          String   @unique // NPR, USD, EUR, INR, etc.
  name          String // Nepalese Rupee, US Dollar, etc.
  symbol        String // ₹, $, €, etc.
  decimalPlaces Int      @default(2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenantCurrencies  TenantCurrency[]
  exchangeRatesFrom ExchangeRate[]   @relation("FromCurrency")
  exchangeRatesTo   ExchangeRate[]   @relation("ToCurrency")
}

model TenantCurrency {
  id         String   @id @default(uuid())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  tenantId   String
  currency   Currency @relation(fields: [currencyId], references: [id])
  currencyId String
  isDefault  Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@unique([tenantId, currencyId])
  @@index([tenantId])
}

model ExchangeRate {
  id             String    @id @default(uuid())
  fromCurrency   Currency  @relation("FromCurrency", fields: [fromCurrencyId], references: [id])
  fromCurrencyId String
  toCurrency     Currency  @relation("ToCurrency", fields: [toCurrencyId], references: [id])
  toCurrencyId   String
  rate           Decimal   @db.Decimal(18, 8)
  source         String? // manual, api, etc.
  validFrom      DateTime  @default(now())
  validTo        DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([fromCurrencyId, toCurrencyId])
  @@index([validFrom])
}

model TaxRate {
  id              String    @id @default(uuid())
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  tenantId        String
  name            String // VAT 13%, TDS 15%, etc.
  code            String // VAT, TDS, WHT, etc.
  rate            Decimal   @db.Decimal(5, 2) // Percentage
  type            String // VAT, TDS, WHT, GST, SALES_TAX
  isCompound      Boolean   @default(false)
  parentTaxRateId String?
  parentTaxRate   TaxRate?  @relation("CompoundTax", fields: [parentTaxRateId], references: [id])
  childTaxRates   TaxRate[] @relation("CompoundTax")
  isActive        Boolean   @default(true)
  governmentCode  String? // IRD code for Nepal
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  taxGroups TaxGroupTaxRate[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([type])
}

model TaxGroup {
  id          String   @id @default(uuid())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
