{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "incremental": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@dexo/shared": ["./packages/shared/src"],
      "@dexo/ui": ["./packages/ui/src"],
      "@dexo/auth": ["./packages/auth/src"],
      "@dexo/tenant": ["./packages/tenant/src"],
      "@dexo/user": ["./packages/user/src"],
      "@dexo/role": ["./packages/role/src"],
      "@dexo/permission": ["./packages/permission/src"],
      "@dexo/subscription": ["./packages/subscription/src"],
      "@dexo/billing": ["./packages/billing/src"],
      "@dexo/notification": ["./packages/notification/src"],
      "@dexo/files": ["./packages/files/src"],
      "@dexo/settings": ["./packages/settings/src"],
      "@dexo/plugin-system": ["./packages/plugin-system/src"],
      "@dexo/dashboard": ["./packages/dashboard/src"],
      "@dexo/api-client": ["./packages/api-client/src"],
      "@dexo/cms": ["./packages/cms/src"],
      "@dexo/analytics": ["./packages/analytics/src"],
      "@dexo/modules": ["./packages/modules/src"],
      "@dexo/tenancy": ["./packages/tenancy/src"],
      "@dexo/blog": ["./packages/blog/src"],
      "@dexo/finance": ["./packages/finance/src"]
    }
  },
  "references": [],
  "include": [
    "apps/api/**/*",
    "packages/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".next",
    "coverage",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.e2e-spec.ts"
  ]
}
