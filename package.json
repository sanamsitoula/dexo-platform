{
  "name": "dexo-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant SaaS platform engine",
  "author": "Dexo Platform Team",
  "license": "PROPRIETARY",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:api": "npm run dev --workspace=@dexo/api",
    "dev:web": "npm run dev --workspace=@dexo/platform-web",
    "dev:admin": "npm run dev --workspace=@dexo/platform-admin",
    "dev:tenant-admin": "npm run dev --workspace=@dexo/tenant-admin",
    "dev:tenant-website": "npm run dev --workspace=@dexo/tenant-website",
    "dev:tenant-app": "npm run dev --workspace=@dexo/tenant-app",
    "dev:mobile": "npm run dev --workspace=@dexo/mobile",
    "lint": "turbo run lint --continue",
    "format": "turbo run format",
    "test": "turbo run test",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json && turbo run type-check --filter=@dexo/platform-web --filter=@dexo/platform-admin --filter=@dexo/tenant-website --filter=@dexo/tenant-admin --filter=@dexo/tenant-app --filter=@dexo/mobile --continue",
    "clean": "turbo run clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node --transpile-only scripts/seed/index.ts",
    "db:seed:v5": "ts-node --transpile-only scripts/seed/index.ts",
    "db:seed:clean": "ts-node --transpile-only scripts/seed/clean.ts",
    "db:seed:fresh": "npm run db:seed:clean && npm run db:seed",
    "db:seed:fitness": "ts-node --transpile-only scripts/seed/03-tenants/fitness-center.ts",
    "db:seed:fitness-full": "ts-node --transpile-only scripts/seed/06-fitness-full-demo.ts",
    "db:verify:fitness": "node scripts/verify-fitness-seed.js",
    "db:seed:restaurant": "ts-node --transpile-only scripts/seed/03-tenants/restaurant.ts",
    "db:seed:ecommerce-demo": "ts-node --transpile-only scripts/seed/09-ecommerce-demo.ts",
    "db:migrate:fresh": "npx prisma migrate reset --force && npm run db:seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "setup": "npm install && npm run db:generate && npm run db:push && npm run db:seed",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "crg:install": "pip install code-review-graph && code-review-graph install",
    "crg:build": "code-review-graph build",
    "crg:update": "code-review-graph update",
    "crg:daemon": "crg-daemon start",
    "crg:status": "code-review-graph status"
  },
  "workspaces": [
    "apps/api",
    "apps/platform-web",
    "apps/platform-admin",
    "apps/tenant-website",
    "apps/tenant-admin",
    "apps/tenant-app",
    "apps/fitness",
    "apps/ecommerce",
    "packages/*"
  ],
  "devDependencies": {
    "@prisma/client": "^5.0.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/bcrypt": "^5.0.0",
    "@types/node": "^18.0.0",
    "autoprefixer": "^10.5.1",
    "changeset": "^0.2.6",
    "dotenv": "^16.4.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.0.0",
    "eslint-plugin-prettier": "^5.5.6",
    "postcss": "^8.5.15",
    "prettier": "^3.0.0",
    "prisma": "^5.0.0",
    "tailwindcss": "^4.3.1",
    "ts-node": "^10.9.0",
    "turbo": "^1.10.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "prisma": {
    "seed": "ts-node --transpile-only scripts/seed/index.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "@nestjs/platform-express": "^10.4.22",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3"
  }
}
